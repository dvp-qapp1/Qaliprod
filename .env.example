# ================================================
# Qalia Environment Variables
# ================================================
# 
# This file documents ALL environment variables used by the application.
# 
# LOCAL DEVELOPMENT SETUP:
# 1. Copy this file to .env.local (this file is git-ignored)
# 2. Fill in the values from your Supabase/service dashboards
# 3. Run `bun dev` to start the development server
#
# The .env.local file takes precedence over .env for local development.
# Never commit real credentials to the repository!
#
# ================================================

# ===================
# Environment Identifier
# ===================
# Used by Sentry and logging to identify the environment
# Values: development | staging | production
NODE_ENV=development

# ===================
# Supabase
# ===================
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
#
# For Development: Use your Supabase DEV project
# For Production: Use your Supabase PROD project
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Database Connection String
# Get from: Supabase Dashboard > Settings > Database > Connection String (URI)
# Note: URL-encode special characters in password (e.g., @ becomes %40)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ===================
# Gemini AI
# ===================
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy...

# Daily budget limit in USD (prevents runaway costs)
# Recommended: 5 for dev, 10 for prod
GEMINI_DAILY_BUDGET_USD=5

# ===================
# Polar.sh (Payments)
# ===================
# Get from: https://polar.sh/settings/developer
# Note: Polar has Test Mode and Live Mode - use Test Mode for development
POLAR_ACCESS_TOKEN=polar_oat_...

# ===================
# Upstash Redis (Rate Limiting)
# ===================
# Get from: https://console.upstash.com/redis
# Shared between dev/prod is OK initially
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# ===================
# Sentry (Error Monitoring)
# ===================
# Get from: https://sentry.io/settings/projects/YOUR_PROJECT/keys/
# Same DSN for both envs - Sentry uses NODE_ENV to differentiate
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# ===================
# Feature Flags
# ===================
# Toggle features on/off per environment
ENABLE_ANALYTICS_TRIGGERS=true
ENABLE_GEMINI_RATE_LIMIT=true
ENABLE_PWA_OFFLINE=false
ENABLE_COMMUNITY_FEATURES=false

# ===================
# Build Overrides (CI/CD Only)
# ===================
# Set to true to skip env validation during Docker build
# DO NOT set this locally - only used in Dockerfile
# SKIP_ENV_VALIDATION=true
